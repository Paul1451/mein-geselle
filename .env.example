# Mein Geselle - Environment Configuration
# Copy this file to .env and fill in the required keys
# Never commit .env (it's in .gitignore)

# OpenRouter API key for LLM access (Claude, Llama, etc.)
# Get it at: https://openrouter.ai/keys
# This key powers all agent decisions and skill learning
OPENROUTER_API_KEY=sk_example_key_here

# Telegram bot token from @BotFather
# Get it at: https://t.me/BotFather
# Go to /newbot → name your bot → BotFather gives you token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmnopqrsTUVwxyzABC

# (Optional) Telegram user IDs allowed to message the bot
# Comma-separated list, e.g. 123456789,987654321
# If empty, only the owner (user ID that created the bot) can use it
TELEGRAM_ALLOWED_USERS=
